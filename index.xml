&lt;script&gt;
(function() {
 var container = document.currentScript.previousElementSibling;
 var buttons = container.querySelectorAll('.skill-filter__btn');
 var pills = container.querySelectorAll('.skill-pill');

 buttons.forEach(function(btn) {
 btn.addEventListener('click', function() {
 var filter = this.dataset.filter;
 buttons.forEach(function(b) { b.classList.remove('active'); });
 this.classList.add('active');
 pills.forEach(function(pill) {
 if (filter === 'all' || pill.dataset.category === filter) {
 pill.classList.remove('skill-pill--hidden');
 } else {
 pill.classList.add('skill-pill--hidden');
 }
 });
 });
 });
})();
&lt;/script&gt;</description></item></channel></rss>